{
    "name": "victorstochero/warden",
    "description": "Self-hosted APM for Laravel with zero external dependencies. Parent/child observability over native Laravel events, stored in your existing RDBMS.",
    "keywords": ["laravel", "apm", "observability", "monitoring", "self-hosted", "tracing"],
    "license": "MIT",
    "type": "library",
    "authors": [
        {
            "name": "Victor Stochero",
            "email": "victor@stochero.dev"
        }
    ],
    "require": {
        "php": "^8.2",
        "illuminate/contracts": "^10.0|^11.0|^12.0|^13.0",
        "illuminate/support": "^10.0|^11.0|^12.0|^13.0",
        "illuminate/database": "^10.0|^11.0|^12.0|^13.0",
        "illuminate/console": "^10.0|^11.0|^12.0|^13.0",
        "illuminate/http": "^10.0|^11.0|^12.0|^13.0"
    },
    "require-dev": {
        "larastan/larastan": "^2.0|^3.0",
        "laravel/pint": "^1.29",
        "orchestra/testbench": "^8.0|^9.0|^10.0|^11.0",
        "phpstan/phpstan": "^1.11|^2.0",
        "phpunit/phpunit": "^10.0|^11.0|^12.0"
    },
    "autoload": {
        "psr-4": {
            "VictorStochero\\Warden\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "VictorStochero\\Warden\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "VictorStochero\\Warden\\WardenServiceProvider"
            ],
            "aliases": {
                "Warden": "VictorStochero\\Warden\\Facades\\Warden"
            }
        }
    },
    "scripts": {
        "test": "phpunit",
        "phpstan": "phpstan analyse",
        "phpstan:baseline": "phpstan analyse --generate-baseline=phpstan-baseline.neon"
    },
    "config": {
        "sort-packages": true
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
